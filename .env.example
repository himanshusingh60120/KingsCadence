# OpenAI (same key you used in Colab)
OPENAI_API_KEY=sk-...

# Google service account (create in Google Cloud Console -> IAM -> Service Accounts,
# enable the Google Sheets API, create a JSON key, then SHARE each spreadsheet with
# this email as Editor)
GOOGLE_SERVICE_ACCOUNT_EMAIL=cadence-bot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# Optional overrides
CHAT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
DISCOUNT=10%
